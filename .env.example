# ============================================
# FaceAuth API - Variáveis de Ambiente
# ============================================

# Conexão com o PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=faceauth
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Connection String completa (usada pelo ASP.NET Core)
CONNECTION_STRING=Host=localhost;Port=5432;Database=faceauth;Username=postgres;Password=postgres

# Reconhecimento Facial
FACE_RECOGNITION_THRESHOLD=0.6

# Caminhos dos modelos (relativos ao diretório de execução)
HAAR_CASCADE_PATH=Models/haarcascade_frontalface_default.xml
SHAPE_PREDICTOR_PATH=Models/shape_predictor_68_face_landmarks.dat
FACE_RECOGNITION_MODEL_PATH=Models/dlib_face_recognition_resnet_model_v1.dat
